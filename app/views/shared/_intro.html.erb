<%# Skippable entry terminal. First visit: boot sequence + shell challenge until solved or skipped.
    Reopen any time with Ctrl+` or Cmd+` (see intro_controller.js).
    Storage key v2 resets the gate for visitors who saw the old v1 challenge. %>
<div class="intro"
     data-controller="intro"
     data-intro-storage-key-value="ahmed-os.intro.v2"
     hidden>
  <div class="intro__terminal" role="dialog" aria-label="Entry terminal">
    <div class="intro__bar">
      <div class="intro__dots" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <span class="intro__title">ahmed@ahmed-os: ~</span>
      <button type="button"
              class="intro__skip"
              data-action="intro#skip"
              aria-label="Skip the entry challenge">skip</button>
    </div>

    <%# Screen starts empty — the boot sequence fills it via intro_controller.js %>
    <div class="intro__screen" data-intro-target="screen"></div>

    <form class="intro__form" data-action="submit->intro#submit">
      <span class="intro__prompt" aria-hidden="true">ahmed@ahmed-os:~$</span>
      <input type="text"
             class="intro__input"
             data-intro-target="input"
             autocomplete="off"
             autocapitalize="off"
             spellcheck="false"
             aria-label="Type a shell command">
    </form>
  </div>
</div>
